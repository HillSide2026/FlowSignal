# Copy this file to .env, or run `pnpm db:setup` to generate one.
# Note: this app reads .env directly for local development.

# Local Docker Postgres default used by docker-compose.yml and pnpm db:setup.
POSTGRES_URL=postgres://postgres:postgres@localhost:54322/postgres

# Public base URL used by local flows that need absolute app URLs.
BASE_URL=http://localhost:3000

# Required for JWT session signing.
# Generate with: openssl rand -hex 32
AUTH_SECRET=replace-with-a-64-character-random-hex-secret
